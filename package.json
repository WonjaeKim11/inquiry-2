{
  "name": "@inquiry/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "nx run-many --targets=serve,dev --projects=@inquiry/server,@inquiry/client --parallel",
    "dev:server": "nx serve @inquiry/server",
    "dev:client": "nx dev @inquiry/client",
    "db:generate": "pnpm --filter @inquiry/db db:generate",
    "db:migrate": "pnpm --filter @inquiry/db db:migrate",
    "db:deploy": "pnpm --filter @inquiry/db db:deploy",
    "db:studio": "pnpm --filter @inquiry/db db:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "private": true,
  "devDependencies": {
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/js": "22.5.0",
    "@nx/nest": "^22.5.0",
    "@nx/next": "^22.5.0",
    "@nx/node": "22.5.0",
    "@nx/web": "22.5.0",
    "@nx/webpack": "22.5.0",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "20.19.9",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "10.4.13",
    "nx": "22.5.0",
    "postcss": "8.4.38",
    "prettier": "^2.6.2",
    "tailwindcss": "3.4.3",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "bcryptjs": "^3.0.3",
    "i18next": "^25.8.13",
    "next": "~16.0.1",
    "nodemailer": "^8.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.5.4",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  }
}
